<?xml version="1.0"?>
<integrations xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Integration:etc/integrations.xsd">
    <integration name="ConvertCart Analytics">
        <email>integration@convertcart.com</email>
        <resources>
            <!-- Sales (READ-ONLY) -->
            <resource name="Magento_Sales::sales"/>
            <resource name="Magento_Sales::orders"/>
            <resource name="Magento_Sales::view"/>
            
            <!-- Catalog (READ-ONLY) -->
            <resource name="Magento_Catalog::catalog"/>
            <resource name="Magento_Catalog::products"/>
            <resource name="Magento_Catalog::categories"/>
            
            <!-- Customer (READ-ONLY) -->
            <resource name="Magento_Customer::customer"/>
            
            <!-- Inventory (READ-ONLY) -->
            <resource name="Magento_CatalogInventory::cataloginventory"/>
            
            <!-- Backend/Config (MINIMAL) -->
            <resource name="Magento_Backend::stores"/>
            <resource name="Magento_Config::config"/>
            
            <!-- ConvertCart Custom -->
            <resource name="Convertcart_Analytics::api"/>
            <resource name="Convertcart_Analytics::sync"/>
            <resource name="Convertcart_Analytics::plugin_info"/>
        </resources>
    </integration>
</integrations>
